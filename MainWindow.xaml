<Window x:Class="CashShopTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CashShop SQL Generator — Sentinel Dev"
        Height="720" Width="980"
        MinHeight="600" MinWidth="860"
        WindowStartupLocation="CenterScreen"
        Background="#0D0B0F"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResize"
        Icon="rf_icon.ico">

    <Window.Resources>
        <!-- Scrollbar style -->
        <Style x:Key="ScrollBarThumb" TargetType="{x:Type Thumb}">
            <Setter Property="Background" Value="#3A1010"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Rectangle Fill="{TemplateBinding Background}" RadiusX="3" RadiusY="3"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="Background" Value="#1A1018"/>
            <Setter Property="Width" Value="6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid Background="{TemplateBinding Background}">
                            <Track Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource ScrollBarThumb}"/>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Button style -->
        <Style x:Key="BtnRed" TargetType="Button">
            <Setter Property="Background" Value="#6B0E0E"/>
            <Setter Property="Foreground" Value="#E8E0D8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#D72020"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#9B1515"/>
                                <Setter Property="BorderBrush" Value="#FF4444"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#4A0808"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#2A1818"/>
                                <Setter Property="Foreground" Value="#555"/>
                                <Setter Property="BorderBrush" Value="#333"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnGold" TargetType="Button">
            <Setter Property="Background" Value="#5A4200"/>
            <Setter Property="Foreground" Value="#FFD060"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#C8A040"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#7A5800"/>
                                <Setter Property="BorderBrush" Value="#FFD060"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#3A2800"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#2A2010"/>
                                <Setter Property="Foreground" Value="#555"/>
                                <Setter Property="BorderBrush" Value="#333"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnDark" TargetType="Button">
            <Setter Property="Background" Value="#1E1820"/>
            <Setter Property="Foreground" Value="#A09898"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#3A3040"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2E2535"/>
                                <Setter Property="Foreground" Value="#D0C8D8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DataGrid style -->
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#120F16"/>
            <Setter Property="Foreground" Value="#D8D0E0"/>
            <Setter Property="BorderBrush" Value="#2A2030"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#1E1825"/>
            <Setter Property="RowBackground" Value="#120F16"/>
            <Setter Property="AlternatingRowBackground" Value="#170D1A"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#1E0A0A"/>
            <Setter Property="Foreground" Value="#C8A040"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="BorderBrush" Value="#3A1010"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
        </Style>
        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1E1020"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#3A1515"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Foreground" Value="#D8D0E0"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="#FFD060"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border BorderBrush="#3A1010" BorderThickness="1" CornerRadius="0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="48"/>   <!-- Title bar -->
                <RowDefinition Height="Auto"/> <!-- Sub header -->
                <RowDefinition Height="Auto"/> <!-- File input area -->
                <RowDefinition Height="Auto"/> <!-- Stats bar -->
                <RowDefinition Height="*"/>    <!-- Main content -->
                <RowDefinition Height="Auto"/> <!-- SQL preview -->
                <RowDefinition Height="48"/>   <!-- Bottom bar -->
            </Grid.RowDefinitions>

            <!-- ═══ TITLE BAR ═══ -->
            <Border Grid.Row="0" Background="#160A0A" MouseLeftButtonDown="TitleBar_MouseDown">
                <Border.Effect>
                    <DropShadowEffect Color="#D72020" BlurRadius="8" ShadowDepth="0" Opacity="0.3"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left accent line -->
                    <Rectangle Grid.Column="0" Width="3" Fill="#D72020" VerticalAlignment="Stretch"/>

                    <!-- Title -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,0,0">
                        <TextBlock Text="⚡" FontSize="16" Foreground="#D72020" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="CASHSHOP SQL GENERATOR" FontSize="13" FontWeight="Bold"
                                   Foreground="#C8A040" FontFamily="Segoe UI"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="  —  Sentinel Dev" FontSize="11" Foreground="#5A5060"
                                   FontFamily="Segoe UI" VerticalAlignment="Center" Margin="4,1,0,0"/>
                    </StackPanel>

                    <!-- Window controls -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,10,0">
                        <Button x:Name="btnMinimize" Content="—" Width="32" Height="28"
                                Style="{StaticResource BtnDark}" Click="btnMinimize_Click" Margin="2,0"/>
                        <Button x:Name="btnClose" Content="✕" Width="32" Height="28"
                                Background="#3A0A0A" Foreground="#D72020"
                                BorderBrush="#5A1010" BorderThickness="1"
                                FontSize="12" Cursor="Hand"
                                Click="btnClose_Click" Margin="2,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="3">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#D72020"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ═══ SUB HEADER ═══ -->
            <Border Grid.Row="1" Background="#100808" Padding="16,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Convert CashShop.xlsx → INSERT SQL for BILLING.dbo.tbl_cashList"
                               FontFamily="Segoe UI" FontSize="11" Foreground="#5A5060" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" x:Name="txtVersion" Text="v1.0"
                               FontFamily="Segoe UI" FontSize="10" Foreground="#3A2830" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- ═══ FILE INPUT ═══ -->
            <Border Grid.Row="2" Background="#140C14" Padding="16,12" BorderBrush="#2A1828" BorderThickness="0,1,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="Excel File" FontFamily="Segoe UI" FontSize="10"
                               FontWeight="Bold" Foreground="#7A6870" VerticalAlignment="Center"
                               Margin="0,0,12,0" Width="65"/>

                    <Border Grid.Column="1" Background="#0E0B12" BorderBrush="#2A2030"
                            BorderThickness="1" CornerRadius="3" Margin="0,0,8,0">
                        <TextBox x:Name="txtFilePath" Background="Transparent" Foreground="#C8C0D0"
                                 BorderThickness="0" FontFamily="Consolas" FontSize="11"
                                 VerticalContentAlignment="Center" Padding="10,6"
                                 IsReadOnly="True" Text="— No file selected —"
                                 CaretBrush="#D72020" SelectionBrush="#3A1515"/>
                    </Border>

                    <Button Grid.Column="2" x:Name="btnBrowse" Content="📂  Browse"
                            Style="{StaticResource BtnDark}" Width="100" Height="32"
                            Margin="0,0,8,0" Click="btnBrowse_Click"/>

                    <Button Grid.Column="3" x:Name="btnLoad" Content="⚡  Load"
                            Style="{StaticResource BtnRed}" Width="90" Height="32"
                            IsEnabled="False" Click="btnLoad_Click"/>
                </Grid>
            </Border>

            <!-- ═══ STATS BAR ═══ -->
            <Border Grid.Row="3" Background="#0E080E" Padding="16,7" BorderBrush="#1E1020" BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,24,0">
                        <TextBlock Text="ROWS" FontFamily="Segoe UI" FontSize="9" FontWeight="Bold"
                                   Foreground="#5A5060" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock x:Name="txtRowCount" Text="0" FontFamily="Segoe UI Semibold"
                                   FontSize="14" Foreground="#C8A040" VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,24,0">
                        <TextBlock Text="SELECTED" FontFamily="Segoe UI" FontSize="9" FontWeight="Bold"
                                   Foreground="#5A5060" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock x:Name="txtSelectedCount" Text="0" FontFamily="Segoe UI Semibold"
                                   FontSize="14" Foreground="#D72020" VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <TextBlock Text="STATUS" FontFamily="Segoe UI" FontSize="9" FontWeight="Bold"
                                   Foreground="#5A5060" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock x:Name="txtStatus" Text="Ready" FontFamily="Segoe UI"
                                   FontSize="11" Foreground="#5A7A5A" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Select all / clear -->
                    <StackPanel Grid.Column="4" Orientation="Horizontal">
                        <Button x:Name="btnSelectAll" Content="Select All" Style="{StaticResource BtnDark}"
                                Width="80" Height="24" FontSize="10" Margin="0,0,6,0"
                                IsEnabled="False" Click="btnSelectAll_Click"/>
                        <Button x:Name="btnClearSel" Content="Clear" Style="{StaticResource BtnDark}"
                                Width="60" Height="24" FontSize="10"
                                IsEnabled="False" Click="btnClearSel_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ═══ MAIN CONTENT — DataGrid ═══ -->
            <Border Grid.Row="4" Margin="16,12,16,0" BorderBrush="#2A1828" BorderThickness="1" CornerRadius="2">
                <DataGrid x:Name="dgItems" AutoGenerateColumns="False"
                          CanUserAddRows="False" CanUserDeleteRows="False"
                          CanUserReorderColumns="False" CanUserResizeRows="False"
                          SelectionChanged="dgItems_SelectionChanged"
                          IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridCheckBoxColumn Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                                Width="40" IsReadOnly="False">
                            <DataGridCheckBoxColumn.HeaderTemplate>
                                <DataTemplate>
                                    <CheckBox x:Name="chkAll" IsChecked="False"
                                              Checked="ChkAll_Checked" Unchecked="ChkAll_Unchecked"
                                              Background="Transparent" BorderBrush="#C8A040"/>
                                </DataTemplate>
                            </DataGridCheckBoxColumn.HeaderTemplate>
                        </DataGridCheckBoxColumn>
                        <DataGridTextColumn Header="No" Binding="{Binding RowNum}" Width="50"/>
                        <DataGridTextColumn Header="name  (Code)" Binding="{Binding Code}" Width="120"/>
                        <DataGridTextColumn Header="id  (CashCode)" Binding="{Binding CashCode}" Width="140"/>
                        <DataGridTextColumn Header="cost  (CsPrice)" Binding="{Binding CsPrice}" Width="120"/>
                        <DataGridTextColumn Header="Preview SQL" Binding="{Binding PreviewSql}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- ═══ SQL PREVIEW ═══ -->
            <Border Grid.Row="5" Margin="16,10,16,0" Background="#0A080D"
                    BorderBrush="#2A1020" BorderThickness="1" CornerRadius="2">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="28"/>
                        <RowDefinition Height="110"/>
                    </Grid.RowDefinitions>

                    <!-- Preview header -->
                    <Border Grid.Row="0" Background="#140A14" BorderBrush="#2A1020" BorderThickness="0,0,0,1">
                        <Grid Margin="10,0">
                            <TextBlock Text="SQL PREVIEW" FontFamily="Segoe UI" FontSize="9"
                                       FontWeight="Bold" Foreground="#7A5060" VerticalAlignment="Center"/>
                            <Button x:Name="btnCopyPreview" Content="Copy" HorizontalAlignment="Right"
                                    Style="{StaticResource BtnDark}" Width="55" Height="20"
                                    FontSize="9" Click="btnCopyPreview_Click"/>
                        </Grid>
                    </Border>

                    <!-- Preview text -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                        <TextBox x:Name="txtPreview" Background="Transparent" Foreground="#9A8090"
                                 FontFamily="Consolas" FontSize="10" BorderThickness="0"
                                 IsReadOnly="True" TextWrapping="NoWrap"
                                 Padding="10,8" VerticalAlignment="Top"
                                 Text="-- Load an Excel file to preview SQL here..."/>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- ═══ BOTTOM BAR ═══ -->
            <Border Grid.Row="6" Background="#160A0A" BorderBrush="#2A1010" BorderThickness="0,1,0,0" Margin="0,10,0,0">
                <Grid Margin="16,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" x:Name="txtBottomStatus"
                               Text="© Sentinel Dev  —  CashShop SQL Generator"
                               FontFamily="Segoe UI" FontSize="10" Foreground="#3A2830"
                               VerticalAlignment="Center"/>

                    <Button Grid.Column="1" x:Name="btnPreviewAll" Content="👁  Preview SQL"
                            Style="{StaticResource BtnDark}" Width="120" Height="32"
                            Margin="0,0,8,0" IsEnabled="False" Click="btnPreviewAll_Click"/>

                    <Button Grid.Column="2" x:Name="btnGenerate" Content="💾  Save .sql"
                            Style="{StaticResource BtnGold}" Width="120" Height="32"
                            Margin="0,0,8,0" IsEnabled="False" Click="btnGenerate_Click"/>

                    <Button Grid.Column="3" x:Name="btnGenerateAll" Content="⚡  Generate ALL"
                            Style="{StaticResource BtnRed}" Width="130" Height="32"
                            IsEnabled="False" Click="btnGenerateAll_Click"/>
                </Grid>
            </Border>

        </Grid>
    </Border>
</Window>
